{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A floor plan project saved by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the project" },
        "userId": { "type": "string", "description": "UID of the owner" },
        "data": { "type": "object", "description": "FloorPlanData object" },
        "imagePreview": { "type": "string", "description": "Base64 image preview" },
        "base64Data": { "type": "string", "description": "Original image base64" },
        "fileType": { "type": "string", "description": "MIME type of original file" },
        "wallHeight": { "type": "number" },
        "wallThickness": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "data", "createdAt"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of user floor plan projects"
    }
  }
}
