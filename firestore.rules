rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: projects
    // Fields:
    //   - userId: string (required) - UID of owner
    //   - data: map (required) - FloorPlanData
    //   - imagePreview: string (optional)
    //   - base64Data: string (optional)
    //   - fileType: string (optional)
    //   - wallHeight: number (optional)
    //   - wallThickness: number (optional)
    //   - createdAt: timestamp (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['userId', 'data', 'createdAt']) &&
             data.userId is string &&
             data.data is map &&
             data.createdAt is timestamp;
    }

    match /projects/{projectId} {
      // Allow anyone to read a project if they have the ID (for sharing)
      allow read: if true;
      
      // Only owner can create/update their own projects
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidProject(request.resource.data);
                      
      allow update: if isOwner(resource.data.userId) &&
                      request.resource.data.userId == resource.data.userId &&
                      isValidProject(request.resource.data);
                      
      allow delete: if isOwner(resource.data.userId);
    }
  }
}
